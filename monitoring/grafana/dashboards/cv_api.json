{
  "__inputs": [],
  "__requires": [
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "Dynamic CV API — request metrics, latency, visitor counter",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "panels": [

    {
      "id": 1,
      "type": "stat",
      "title": "Всего запросов к API",
      "description": "Источник: cv_api_requests_total — Counter, который наш PrometheusMiddleware инкрементирует после каждого HTTP-ответа. Метка endpoint позволяет разбивать по маршрутам, но здесь мы суммируем все.",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1000 },
              { "color": "red", "value": 10000 }
            ]
          },
          "unit": "short",
          "mappings": []
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background", "graphMode": "none" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(cv_api_requests_total)",
          "legendFormat": "Total",
          "refId": "A"
        }
      ]
    },

    {
      "id": 2,
      "type": "stat",
      "title": "Уникальных Посетителей",
      "description": "Источник: cv_visitors_total — Counter, который инкрементируется в роутере GET /api/profile только если SHA-256 хеш IP-адреса посетителя ещё не встречался в таблице visitors (PostgreSQL). Таким образом каждый уникальный IP считается ровно один раз за всё время.",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          },
          "unit": "short",
          "mappings": []
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background", "graphMode": "none" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "cv_visitors_total",
          "legendFormat": "Visitors",
          "refId": "A"
        }
      ]
    },

    {
      "id": 3,
      "type": "stat",
      "title": "Error Rate (последние 5 мин)",
      "description": "Источник: cv_api_requests_total с фильтром по метке status_code. Регулярное выражение '5..' ловит все 5xx-коды. Результат — доля ошибочных запросов от общего числа за скользящее окно 5 минут. Значение 0 = всё хорошо.",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          },
          "unit": "percentunit",
          "mappings": []
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background", "graphMode": "none" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(cv_api_requests_total{status_code=~\"5..\"}[5m])) / sum(rate(cv_api_requests_total[5m]))",
          "legendFormat": "Error Rate",
          "refId": "A"
        }
      ]
    },

    {
      "id": 4,
      "type": "stat",
      "title": "P95 Latency (последние 5 мин)",
      "description": "Источник: cv_api_request_duration_seconds — Histogram. Каждый запрос через PrometheusMiddleware замеряется через time.perf_counter() до и после вызова next handler. Prometheus хранит bucket-ы (граничные значения времени) и позволяет вычислять перцентили. P95 означает: 95% запросов выполняются быстрее этого времени.",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 1.0 }
            ]
          },
          "unit": "s",
          "mappings": []
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background", "graphMode": "none" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(cv_api_request_duration_seconds_bucket[5m])))",
          "legendFormat": "P95",
          "refId": "A"
        }
      ]
    },

    {
      "id": 5,
      "type": "timeseries",
      "title": "Request Rate по эндпоинтам (req/s)",
      "description": "Источник: rate(cv_api_requests_total[5m]) — функция rate() берёт Counter и вычисляет среднюю скорость роста за указанное окно (5 мин). Метка endpoint позволяет видеть какой маршрут нагружен больше. Это ключевой график для понимания трафика на API.",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10, "gradientMode": "none", "showPoints": "never" },
          "unit": "reqps"
        },
        "overrides": []
      },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (endpoint) (rate(cv_api_requests_total[5m]))",
          "legendFormat": "{{ endpoint }}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 6,
      "type": "timeseries",
      "title": "Latency Percentiles (P50 / P95 / P99)",
      "description": "Источник: histogram_quantile() над cv_api_request_duration_seconds_bucket. Histogram сохраняет количество запросов попавших в каждый временной bucket (0.005s, 0.01s, 0.025s ... 10s). histogram_quantile интерполирует из этих данных нужный перцентиль. P50 = медиана, P95 = типичный «медленный» запрос, P99 = почти худший случай.",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 5, "gradientMode": "none", "showPoints": "never" },
          "unit": "s"
        },
        "overrides": []
      },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, sum by (le) (rate(cv_api_request_duration_seconds_bucket[5m])))",
          "legendFormat": "P50",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(cv_api_request_duration_seconds_bucket[5m])))",
          "legendFormat": "P95",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum by (le) (rate(cv_api_request_duration_seconds_bucket[5m])))",
          "legendFormat": "P99",
          "refId": "C"
        }
      ]
    },

    {
      "id": 7,
      "type": "timeseries",
      "title": "HTTP Status Codes (req/s)",
      "description": "Источник: cv_api_requests_total сгруппированный по метке status_code. Позволяет видеть соотношение 2xx (успех), 4xx (ошибки клиента) и 5xx (ошибки сервера) во времени. Резкий рост 5xx — признак проблем на бэкенде или БД.",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10, "gradientMode": "none", "showPoints": "never" },
          "unit": "reqps"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "2xx" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "4xx" }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "5xx" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
        ]
      },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(cv_api_requests_total{status_code=~\"2..\"}[5m]))",
          "legendFormat": "2xx",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(cv_api_requests_total{status_code=~\"4..\"}[5m]))",
          "legendFormat": "4xx",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(cv_api_requests_total{status_code=~\"5..\"}[5m]))",
          "legendFormat": "5xx",
          "refId": "C"
        }
      ]
    },

    {
      "id": 8,
      "type": "timeseries",
      "title": "Уникальные посетители (накопительно)",
      "description": "Источник: cv_visitors_total — Counter растёт только вверх и никогда не сбрасывается (пока контейнер жив). График показывает накопительный рост уникальных посетителей во времени. Крутой подъём = всплеск новых посетителей.",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "blue", "mode": "fixed" },
          "custom": { "lineWidth": 2, "fillOpacity": 15, "gradientMode": "opacity", "showPoints": "never" },
          "unit": "short"
        },
        "overrides": []
      },
      "options": { "tooltip": { "mode": "single" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "cv_visitors_total",
          "legendFormat": "Unique visitors",
          "refId": "A"
        }
      ]
    }

  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["cv", "fastapi", "devops"],
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Dynamic CV — API Metrics",
  "uid": "cv-api-metrics",
  "version": 1
}
